# ReconForge V2 Environment Variables
# Copy to .env and fill in your keys

# ── LLM Providers (V2 — dual provider) ──────────────────────────
# NVIDIA NIM — DeepSeek V4 Flash for heavy reasoning tasks
# Get free key: https://build.nvidia.com/
NVIDIA_NIM_API_KEY=nvapi-xxxx
NVIDIA_NIM_MODEL=deepseek-ai/deepseek-v4-flash

# Groq — fast open models for repetitive tasks (800+ tok/s)
# Get free key: https://console.groq.com/
GROQ_API_KEY=gsk_xxxx
GROQ_MODEL_FAST=llama-3.3-70b-versatile
GROQ_MODEL_REASONING=deepseek-r1-distill-llama-70b

# Provider preference (auto-routing handles this, but can override)
LLM_HEAVY_PROVIDER=nvidia_nim
LLM_FAST_PROVIDER=groq

# ── Tool API Keys (optional) ─────────────────────────────────────
SHODAN_API_KEY=
GITHUB_TOKEN=
